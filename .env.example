# testsmith configuration
# Copy this file to .env and fill in your values.
# Environment variables always take priority over .env values.

# ── LLM Provider (at least one required) ──────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=AIza...
# GEMINI_API_KEY=AIza...

# ── Provider defaults (optional) ──────────────────────────────
# TESTSMITH_PROVIDER=gemini          # Force provider: anthropic | gemini
# TESTSMITH_MODEL=gemini-2.5-pro    # Default model
# TESTSMITH_TEMPERATURE=0.5         # Sampling temperature (0.0–2.0)
# TESTSMITH_TOP_P=0.9               # Nucleus sampling (0.0–1.0)

# ── Confluence (required for Confluence URLs) ─────────────────
# CONFLUENCE_BASE_URL=https://your-site.atlassian.net
# CONFLUENCE_EMAIL=you@example.com
# CONFLUENCE_API_TOKEN=your-api-token

# ── Figma (required for Figma URLs) ───────────────────────────
# FIGMA_API_TOKEN=your-figma-token
